---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout
  title="404 — Página no encontrada | Estructura"
  description="La página que buscas no existe."
>
  <section class="py-32 sm:py-40 flex items-center justify-center">
    <div class="text-center max-w-lg px-4">
      <p class="text-8xl font-serif text-primary-200">404</p>
      <h1 class="mt-4 text-2xl sm:text-3xl font-serif text-primary-900">
        Página no encontrada
      </h1>
      <p class="mt-4 text-primary-500 leading-relaxed">
        La página que buscas no existe o fue movida. Verifica la URL o regresa al inicio.
      </p>
      <a
        href="/"
        class="mt-8 inline-flex items-center justify-center px-8 py-3.5 bg-primary-700 hover:bg-primary-800 text-white font-medium rounded-lg transition-colors text-sm"
      >
        Volver al inicio
      </a>
    </div>
  </section>
</BaseLayout>
