---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allArticulos = await getCollection("articulos", ({ data }) => !data.draft);
const articulos = allArticulos.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const categoryLabels: Record<string, string> = {
  pensiones: "Pensiones",
  laboral: "Mercados Laborales",
  datos: "Datos",
};

const categoryColors: Record<string, string> = {
  pensiones: "bg-blue-100 text-blue-800",
  laboral: "bg-emerald-100 text-emerald-800",
  datos: "bg-violet-100 text-violet-800",
};
---

<BaseLayout
  title="Publicaciones — Estructura"
  description="Artículos de investigación sobre pensiones, mercados laborales e infraestructura de datos en México."
>
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="max-w-2xl mb-12">
        <h1 class="text-3xl sm:text-4xl font-serif font-bold text-primary-950">
          Publicaciones
        </h1>
        <p class="mt-4 text-lg text-primary-600 leading-relaxed">
          Investigación y análisis sobre pensiones, mercados laborales e infraestructura de datos en México.
        </p>
      </div>

      <!-- Articles Grid -->
      {articulos.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {articulos.map((articulo) => {
            const formattedDate = articulo.data.date.toLocaleDateString("es-MX", {
              year: "numeric",
              month: "long",
              day: "numeric",
            });
            return (
              <a
                href={`/publicaciones/${articulo.id}/`}
                class="group block bg-white border border-primary-100 rounded-xl p-6 hover:shadow-lg hover:border-primary-200 transition-all duration-200"
              >
                <div class="flex items-center gap-3 mb-3">
                  <span
                    class={`inline-block px-2.5 py-0.5 text-xs font-semibold rounded-full ${categoryColors[articulo.data.category]}`}
                  >
                    {categoryLabels[articulo.data.category]}
                  </span>
                  <time
                    datetime={articulo.data.date.toISOString()}
                    class="text-xs text-primary-400"
                  >
                    {formattedDate}
                  </time>
                </div>
                <h2 class="text-lg font-serif font-bold text-primary-900 group-hover:text-accent-700 transition-colors leading-snug">
                  {articulo.data.title}
                </h2>
                <p class="mt-2 text-sm text-primary-600 leading-relaxed line-clamp-3">
                  {articulo.data.description}
                </p>
                {articulo.data.tags.length > 0 && (
                  <div class="mt-4 flex flex-wrap gap-1.5">
                    {articulo.data.tags.slice(0, 3).map((tag: string) => (
                      <span class="px-2 py-0.5 text-xs bg-primary-50 text-primary-600 rounded">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </a>
            );
          })}
        </div>
      ) : (
        <div class="text-center py-16">
          <p class="text-primary-500 text-lg">
            Proximamente publicaremos nuevos artículos de investigación.
          </p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
