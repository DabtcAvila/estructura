---
const currentYear = new Date().getFullYear();

const footerLinks = [
  { href: "#nosotros", label: "Nosotros" },
  { href: "#investigacion", label: "Investigación" },
  { href: "#indepar", label: "INDEPAR" },
  { href: "#contacto", label: "Contacto" },
];
---

<footer class="bg-primary-950 text-primary-200">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- Brand -->
      <div>
        <span class="text-2xl font-serif font-bold text-white">Estructura</span>
        <p class="mt-4 text-sm text-primary-300 leading-relaxed max-w-sm">
          Anuario Nacional de Estrategia, Riesgo y Datos.
          Investigación y analítica de datos enfocada en México.
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="text-sm font-sans font-semibold text-white uppercase tracking-wider mb-4">
          Navegación
        </h3>
        <ul class="space-y-3">
          {footerLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-primary-300 hover:text-accent-400 transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Social & Connect -->
      <div>
        <h3 class="text-sm font-sans font-semibold text-white uppercase tracking-wider mb-4">
          Conecta
        </h3>
        <a
          href="https://www.linkedin.com/company/estructuramexico"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm text-primary-300 hover:text-accent-400 transition-colors"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
        <div class="mt-6">
          <p class="text-xs text-primary-400">
            Datos de fuentes oficiales: CONSAR, INEGI, Banxico
          </p>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-primary-800 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-primary-400">
        &copy; {currentYear} Estructura. Todos los derechos reservados.
      </p>
      <p class="text-xs text-primary-500">
        México
      </p>
    </div>
  </div>
</footer>
