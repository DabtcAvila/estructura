---
const values = [
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 0 0 6 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0 1 18 16.5h-2.25m-7.5 0h7.5m-7.5 0-1 3m8.5-3 1 3m0 0 .5 1.5m-.5-1.5h-9.5m0 0-.5 1.5m.75-9 3-3 2.148 2.148A12.061 12.061 0 0 1 16.5 7.605" /></svg>`,
    title: "Rigor analítico",
    description: "Metodologías sólidas respaldadas por datos de fuentes oficiales. Cada análisis es verificable y reproducible.",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5V6.75a4.5 4.5 0 1 1 9 0v3.75M3.75 21.75h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H3.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" /></svg>`,
    title: "Acceso abierto",
    description: "Creemos en la democratización de la información. Nuestras investigaciones están disponibles para todos.",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" /></svg>`,
    title: "Independencia",
    description: "Sin conflictos de interés. Nuestro único compromiso es con la calidad y la objetividad del análisis.",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m20.893 13.393-1.135-1.135a2.252 2.252 0 0 1-.421-.585l-1.08-2.16a.414.414 0 0 0-.663-.107.827.827 0 0 1-.812.21l-1.273-.363a.89.89 0 0 0-.738 1.595l.587.39c.59.395.674 1.23.172 1.732l-.2.2c-.212.212-.33.498-.33.796v.41c0 .409-.11.809-.32 1.158l-1.315 2.191a2.11 2.11 0 0 1-1.81 1.025 1.055 1.055 0 0 1-1.055-1.055v-1.172c0-.92-.56-1.747-1.414-2.089l-.655-.261a2.25 2.25 0 0 1-1.383-2.46l.007-.042a2.25 2.25 0 0 1 .29-.787l.09-.15a2.25 2.25 0 0 1 2.37-1.048l1.178.236a1.125 1.125 0 0 0 1.302-.795l.208-.73a1.125 1.125 0 0 0-.578-1.315l-.665-.332-.091.091a2.25 2.25 0 0 1-1.591.659h-.18a.94.94 0 0 0-.662.274.931.931 0 0 1-1.458-1.137l1.411-2.353a2.25 2.25 0 0 0 .286-.76m11.928 9.869A9 9 0 0 0 8.965 3.525m11.928 9.868A9 9 0 1 1 8.965 3.525" /></svg>`,
    title: "Enfoque México",
    description: "Especializados en la realidad mexicana. Entendemos el contexto local para generar insights relevantes.",
  },
];
---

<section id="nosotros" class="py-24 sm:py-32 bg-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl">
      <span class="inline-flex items-center gap-2 text-accent-600 text-sm font-medium tracking-wider uppercase">
        <span class="w-8 h-px bg-accent-600"></span>
        Nosotros
      </span>
      <h2 class="mt-4 text-3xl sm:text-4xl font-serif text-primary-900">
        Investigación que transforma datos en decisiones
      </h2>
      <p class="mt-6 text-lg text-primary-600 leading-relaxed">
        Estructura es una firma de investigación y analítica de datos enfocada en México.
        Trabajamos con fuentes oficiales — CONSAR, INEGI, Banxico — para producir
        análisis riguroso sobre los temas más relevantes para el futuro del país.
      </p>
    </div>

    <!-- Values Grid -->
    <div class="mt-16 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {values.map((value) => (
        <div class="group">
          <div class="w-12 h-12 rounded-lg bg-primary-50 group-hover:bg-accent-50 flex items-center justify-center text-primary-700 group-hover:text-accent-600 transition-colors">
            <Fragment set:html={value.icon} />
          </div>
          <h3 class="mt-4 text-lg font-sans font-semibold text-primary-900">
            {value.title}
          </h3>
          <p class="mt-2 text-sm text-primary-500 leading-relaxed">
            {value.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
