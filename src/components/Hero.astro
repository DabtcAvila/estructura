---
const metrics = [
  { value: "CONSAR", label: "Pensiones" },
  { value: "INEGI", label: "Mercados laborales" },
  { value: "Banxico", label: "Datos financieros" },
];
---

<section class="relative overflow-hidden bg-gradient-to-br from-primary-950 via-primary-900 to-primary-800">
  <!-- Subtle grid pattern -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=%2260%22 height=%2260%22 viewBox=%220 0 60 60%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cg fill=%22none%22 fill-rule=%22evenodd%22%3E%3Cg fill=%22%23ffffff%22 fill-opacity=%221%22%3E%3Cpath d=%22M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z%22/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-24 sm:py-32 lg:py-40">
    <div class="max-w-4xl">
      <!-- Tagline -->
      <div class="mb-6">
        <span class="inline-flex items-center gap-2 text-accent-400 text-sm font-medium tracking-wider uppercase">
          <span class="w-8 h-px bg-accent-400"></span>
          Investigación y Analítica de Datos
        </span>
      </div>

      <!-- Title -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-serif text-white leading-tight">
        Anuario Nacional de<br />
        <span class="text-accent-400">Estrategia, Riesgo y Datos</span>
      </h1>

      <!-- Subtitle -->
      <p class="mt-6 text-lg sm:text-xl text-primary-200 leading-relaxed max-w-2xl">
        Generamos investigación rigurosa sobre pensiones, mercados laborales e
        infraestructura de datos en México. Acceso abierto, fuentes oficiales,
        independencia analítica.
      </p>

      <!-- CTAs -->
      <div class="mt-10 flex flex-col sm:flex-row gap-4">
        <a
          href="#investigacion"
          class="inline-flex items-center justify-center px-8 py-3.5 bg-accent-600 hover:bg-accent-700 text-white font-medium rounded-lg transition-colors text-sm"
        >
          Nuestras investigaciones
        </a>
        <a
          href="#contacto"
          class="inline-flex items-center justify-center px-8 py-3.5 border border-primary-400 hover:border-white text-primary-200 hover:text-white font-medium rounded-lg transition-colors text-sm"
        >
          Contacto
        </a>
      </div>
    </div>

    <!-- Metrics bar -->
    <div class="mt-20 pt-8 border-t border-primary-700/50">
      <p class="text-xs text-primary-400 uppercase tracking-wider mb-6">
        Fuentes de datos oficiales
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 sm:gap-12">
        {metrics.map((m) => (
          <div>
            <p class="text-2xl sm:text-3xl font-serif text-white">{m.value}</p>
            <p class="mt-1 text-sm text-primary-300">{m.label}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
