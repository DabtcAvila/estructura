---
const areas = [
  {
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0 0 12 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75Z" /></svg>`,
    title: "Sistemas de Pensiones",
    description: "Análisis integral del sistema de ahorro para el retiro en México. Evaluamos rendimientos de AFORES, comisiones, cobertura y sostenibilidad a largo plazo con datos de CONSAR.",
    tags: ["AFORES", "CONSAR", "Retiro", "SAR"],
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" /></svg>`,
    title: "Mercados Laborales",
    description: "Investigación sobre empleo, informalidad, brechas salariales y dinámica del mercado de trabajo mexicano. Utilizamos microdatos de INEGI y encuestas especializadas.",
    tags: ["Empleo", "INEGI", "Informalidad", "Salarios"],
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" /></svg>`,
    title: "Infraestructura de Datos",
    description: "Consultoría y desarrollo de capacidades para la gestión, procesamiento y visualización de datos. Ayudamos a organizaciones a construir su infraestructura analítica.",
    tags: ["Big Data", "Analytics", "Consultoría", "Pipelines"],
  },
];
---

<section id="investigacion" class="py-24 sm:py-32 bg-primary-50/50">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto">
      <span class="inline-flex items-center gap-2 text-accent-600 text-sm font-medium tracking-wider uppercase mx-auto">
        <span class="w-8 h-px bg-accent-600"></span>
        Áreas de Investigación
        <span class="w-8 h-px bg-accent-600"></span>
      </span>
      <h2 class="mt-4 text-3xl sm:text-4xl font-serif text-primary-900">
        Tres pilares de análisis
      </h2>
      <p class="mt-6 text-lg text-primary-600 leading-relaxed">
        Nuestra investigación se concentra en las áreas con mayor impacto en el
        desarrollo económico y social de México.
      </p>
    </div>

    <!-- Cards -->
    <div class="mt-16 grid grid-cols-1 lg:grid-cols-3 gap-8">
      {areas.map((area) => (
        <div class="bg-white rounded-2xl p-8 shadow-sm border border-primary-100 hover:shadow-lg hover:border-accent-200 transition-all duration-300 group">
          <div class="w-14 h-14 rounded-xl bg-primary-50 group-hover:bg-accent-50 flex items-center justify-center text-primary-700 group-hover:text-accent-600 transition-colors">
            <Fragment set:html={area.icon} />
          </div>
          <h3 class="mt-6 text-xl font-sans font-bold text-primary-900">
            {area.title}
          </h3>
          <p class="mt-3 text-sm text-primary-500 leading-relaxed">
            {area.description}
          </p>
          <div class="mt-6 flex flex-wrap gap-2">
            {area.tags.map((tag) => (
              <span class="inline-block px-3 py-1 text-xs font-medium bg-primary-50 text-primary-600 rounded-full">
                {tag}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
