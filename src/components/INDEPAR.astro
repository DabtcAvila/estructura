---
const highlights = [
  { label: "Análisis de rendimientos de AFORES y SIEFORES" },
  { label: "Estudios de cobertura y brecha pensionaria" },
  { label: "Proyecciones de sostenibilidad del SAR" },
  { label: "Investigación sobre reforma de pensiones 2020-2030" },
];
---

<section id="indepar" class="py-24 sm:py-32 bg-primary-900 relative overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute inset-0 opacity-5">
    <div class="absolute top-0 right-0 w-96 h-96 bg-accent-400 rounded-full blur-3xl translate-x-1/2 -translate-y-1/2"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-primary-400 rounded-full blur-3xl -translate-x-1/2 translate-y-1/2"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <!-- Text Content -->
      <div>
        <span class="inline-flex items-center gap-2 text-accent-400 text-sm font-medium tracking-wider uppercase">
          <span class="w-8 h-px bg-accent-400"></span>
          Instituto Especializado
        </span>
        <h2 class="mt-4 text-3xl sm:text-4xl font-serif text-white">
          INDEPAR
        </h2>
        <p class="mt-2 text-lg text-accent-400 font-medium">
          Instituto de Investigación de Pensiones y Ahorro para el Retiro
        </p>
        <p class="mt-6 text-primary-200 leading-relaxed">
          INDEPAR es nuestra unidad de investigación especializada en el sistema de
          pensiones mexicano. A través de análisis cuantitativo riguroso, evaluamos
          la eficiencia, cobertura y sostenibilidad del Sistema de Ahorro para el Retiro (SAR).
        </p>
        <p class="mt-4 text-primary-300 leading-relaxed">
          Trabajamos exclusivamente con datos oficiales de CONSAR para garantizar
          la objetividad y reproducibilidad de nuestros análisis.
        </p>
      </div>

      <!-- Highlights Card -->
      <div class="bg-primary-800/50 backdrop-blur-sm rounded-2xl p-8 border border-primary-700/50">
        <h3 class="text-sm font-sans font-semibold text-accent-400 uppercase tracking-wider mb-6">
          Líneas de investigación
        </h3>
        <ul class="space-y-4">
          {highlights.map((item) => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-accent-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
              </svg>
              <span class="text-primary-200">{item.label}</span>
            </li>
          ))}
        </ul>

        <div class="mt-8 pt-6 border-t border-primary-700/50">
          <p class="text-xs text-primary-400">
            Fuente de datos: Comisión Nacional del Sistema de Ahorro para el Retiro (CONSAR)
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
